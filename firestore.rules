rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // --- COLLECTION RULES ---

    /**
     * @path /userProfiles/{uid}
     * Users manage their own profile. Wallet balance and budget are stored here.
     */
    match /userProfiles/{uid} {
      allow create: if isOwner(uid);
      allow read: if signedIn(); // Allow others to read name for vendor/order context
      allow update: if isOwner(uid);
    }

    /**
     * @path /vendors/{vendorId}
     * Publicly readable. Managed by vendor users.
     */
    match /vendors/{vendorId} {
      allow read: if signedIn();
      allow create: if signedIn() && isOwner(request.resource.data.userId);
      allow update: if signedIn() && isOwner(resource.data.userId);
    }

    /**
     * @path /products/{productId}
     * Publicly readable. Managed by vendors.
     */
    match /products/{productId} {
      allow read: if signedIn();
      allow create: if signedIn() && isOwner(request.resource.data.vendorOwnerId);
      allow update: if signedIn() && isOwner(resource.data.vendorOwnerId);
      allow delete: if signedIn() && isOwner(resource.data.vendorOwnerId);
    }

    /**
     * @path /users/{studentId}/orders/{orderId}
     * Path-based ownership for orders and their nested items.
     */
    match /users/{studentId}/orders/{orderId} {
      allow read, write: if isOwner(studentId);
      
      match /orderItems/{itemId} {
        allow read, write: if isOwner(studentId);
      }
    }

    /**
     * @path collectionGroup orderItems
     * Allows vendors to see items belonging to them across all student orders.
     */
    match /{path=**}/orderItems/{itemId} {
      allow read: if signedIn() && isOwner(resource.data.vendorOwnerId);
    }

    /**
     * @path /users/{studentId}/expenses/{expenseId}
     */
    match /users/{studentId}/expenses/{expenseId} {
      allow read, write: if isOwner(studentId);
    }

    /**
     * @path /categories/{categoryId}
     */
    match /categories/{categoryId} {
      allow read: if signedIn();
    }
  }
}