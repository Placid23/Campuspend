rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // --- COLLECTION RULES ---

    /**
     * @path /userProfiles/{uid}
     * Users can manage their own profile data.
     */
    match /userProfiles/{uid} {
      allow read, write: if isOwner(uid);
    }

    /**
     * @path /vendors/{vendorId}
     * Anyone signed in can view vendors. Vendors can manage their own profile.
     */
    match /vendors/{vendorId} {
      allow read: if signedIn();
      allow create: if signedIn() && isOwner(request.resource.data.userId);
      allow update: if signedIn() && isOwner(resource.data.userId);
      allow delete: if false; // Only via admin panel (future)
    }

    /**
     * @path /products/{productId}
     * Anyone signed in can view products. Vendors manage their own products.
     */
    match /products/{productId} {
      allow read: if signedIn();
      allow create: if signedIn() && isOwner(request.resource.data.vendorOwnerId);
      allow update: if signedIn() && isOwner(resource.data.vendorOwnerId);
      allow delete: if signedIn() && isOwner(resource.data.vendorOwnerId);
    }

    /**
     * @path /users/{studentId}/orders/{orderId}
     * Path-based ownership for orders.
     */
    match /users/{studentId}/orders/{orderId} {
      allow read, write: if isOwner(studentId);
    }

    /**
     * @path /users/{studentId}/expenses/{expenseId}
     * Path-based ownership for expense tracking.
     */
    match /users/{studentId}/expenses/{expenseId} {
      allow read, write: if isOwner(studentId);
    }

    /**
     * @path /categories/{categoryId}
     */
    match /categories/{categoryId} {
      allow read: if signedIn();
    }
  }
}