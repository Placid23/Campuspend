rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @path /userProfiles/{userId}
     */
    match /userProfiles/{userId} {
      allow get: if signedIn();
      allow list: if signedIn(); 
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
    }

    /**
     * @path /vendors/{vendorId}
     */
    match /vendors/{vendorId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @path /products/{productId}
     */
    match /products/{productId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.vendorOwnerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.vendorOwnerId == request.auth.uid;
    }

    /**
     * @path /users/{studentId}/*
     * Covers subcollections: orders, expenses, budgets, orderItems (direct)
     */
    match /users/{studentId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == studentId;
    }

    /**
     * @path collectionGroup orderItems
     * REQUIRED for Vendors to query their specific sales.
     * The query MUST include: where("vendorOwnerId", "==", auth.uid)
     */
    match /{path=**}/orderItems/{itemId} {
      allow list: if signedIn() && (
        resource.data.vendorOwnerId == request.auth.uid ||
        resource.data.studentId == request.auth.uid
      );
      allow get: if signedIn();
    }
  }
}