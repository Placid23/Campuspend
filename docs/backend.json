
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user of the CampusSpend application, encompassing students, vendors, and administrators.",
      "properties": {
        "id": { "type": "string" },
        "firebaseUid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "walletBalance": { "type": "number" },
        "monthlyBudget": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firebaseUid", "email", "name", "role", "createdAt", "updatedAt"]
    },
    "WalletTransaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WalletTransaction",
      "type": "object",
      "description": "Records every Naira inflow and outflow from a student's digital wallet.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["funding", "spending", "refund"] },
        "description": { "type": "string" },
        "reference": { "type": "string", "description": "External payment ID or Internal order ID" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "amount", "type", "description", "timestamp"]
    },
    "Vendor": {
      "title": "Vendor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "userId": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "status": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "vendorOwnerId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": { "entityName": "UserProfile", "description": "Core profile data." }
      },
      {
        "path": "/users/{studentId}/walletTransactions/{txId}",
        "definition": { "entityName": "WalletTransaction", "description": "Audit trail for all Naira movements." }
      },
      {
        "path": "/users/{studentId}/orders/{orderId}",
        "definition": { "entityName": "Order", "description": "Purchase-based logs." }
      },
      {
        "path": "/vendors/{vendorId}",
        "definition": { "entityName": "Vendor", "description": "Store profiles." }
      }
    ]
  }
}
